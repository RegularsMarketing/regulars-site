{# FOOTER: minimal — brand + a single inline link row #}
<footer class="footer--minimal">
  <div class="wrap">
    <div class="footer-min-top">
      <a class="footer-brand" href="/">
        <img class="logo-mark" src="{{ site.images.logo_mark }}" alt="{{ site.business.name }}">
        <div class="logo-word">{{ site.business.name }}</div>
      </a>
      <div class="footer-min-links">
        {% for col in site.footer.columns %}{% for link in col.links %}
        <a href="{{ link.url }}">{{ link.label }}</a>
        {% endfor %}{% endfor %}
      </div>
    </div>
    {% if site.contact.hours and site.contact.hours.length %}
    <div class="fhours fhours--minimal">
      {% for h in site.contact.hours %}
      <div class="fh-row"><span>{{ h.days }}</span><span>{{ h.hours }}</span></div>
      {% endfor %}
    </div>
    {% endif %}
    {% if site.contact.phone or site.contact.address %}
    <div class="fcontact fcontact--minimal">{% if site.contact.phone %}{{ site.contact.phone }}{% endif %}{% if site.contact.phone and site.contact.address %} · {% endif %}{% if site.contact.address %}{{ site.contact.address }}{% endif %}</div>
    {% endif %}
    <div class="footer-bottom">
      <div class="fl">{{ site.footer.legal_left }}</div>
      <div class="fl">{{ site.footer.legal_right }}</div>
    </div>
  </div>
</footer>

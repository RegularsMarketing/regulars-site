{# FOOTER: three-column (original) #}
<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img class="logo-mark" src="{{ site.images.logo_mark }}" alt="{{ site.business.name }}" width="28" height="28" loading="lazy">
          <div class="logo-word">{{ site.business.name }}</div>
        </div>
        <p class="fdesc">{{ site.footer.description }}</p>
        {% if site.contact.hours and site.contact.hours.length %}
        <div class="fhours">
          {% for h in site.contact.hours %}
          <div class="fh-row"><span>{{ h.days }}</span><span>{{ h.hours }}</span></div>
          {% endfor %}
        </div>
        {% endif %}
        {% if site.contact.phone or site.contact.address %}
        <div class="fcontact">{% if site.contact.phone %}{{ site.contact.phone }}{% endif %}{% if site.contact.phone and site.contact.address %} · {% endif %}{% if site.contact.address %}{{ site.contact.address }}{% endif %}</div>
        {% endif %}
        {% if site.contact.social and site.contact.social.length %}
        <div class="fsocial">
          {% for s in site.contact.social %}<a href="{{ s.url }}" rel="me">{{ s.label }}</a>{% endfor %}
        </div>
        {% endif %}
      </div>
      {% for col in site.footer.columns %}
      <div>
        <h4>{{ col.title }}</h4>
        <ul class="flinks">
          {% for link in col.links %}
          <li><a href="{{ link.url }}">{{ link.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>
    <div class="footer-bottom">
      <div class="fl">{{ site.footer.legal_left }}</div>
      <div class="fl">{{ site.footer.legal_right }}</div>
    </div>
  </div>
</footer>

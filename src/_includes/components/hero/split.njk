{# HERO: split text / image — copy on the left, image panel on the right #}
<section class="hero-split">
  <div class="wrap hero-split-grid">
    <div class="hero-split-text reveal">
      <div class="eyebrow">{{ hero.eyebrow }}</div>
      <h1>{{ hero.headline }}</h1>
      <p class="sub">{{ hero.subhead }}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="{{ hero.primary_cta.url }}">{{ hero.primary_cta.label }}</a>
        <a class="btn btn-outline" href="{{ hero.secondary_cta.url }}">{{ hero.secondary_cta.label }}</a>
      </div>
    </div>
    <div class="hero-split-media reveal">
      {# width/height are the wordmark's intrinsic 900x600. Without them this
         image — the largest above the fold and the LCP candidate — reserved no
         space and was the only real CLS source on the page. Every other <img>
         in the repo already carries them.
         fetchpriority stays and loading="lazy" stays OFF: this is above the
         fold, so lazy-loading it would delay the LCP it is meant to win. #}
      <img src="{{ hero.bg_image if hero.bg_image else site.images.hero_logo }}" alt="{{ site.business.name }}" width="900" height="600" fetchpriority="high" decoding="async">
    </div>
  </div>
</section>

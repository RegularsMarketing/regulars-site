{# HERO: full-bleed photo — dark full-width band. Set `hero.bg_image` in the config to
   drop in an actual photo; without one it falls back to a solid charcoal band. #}
<section class="hero-fullbleed"{% if hero.bg_image %} style="background-image:linear-gradient(color-mix(in srgb, var(--charcoal) 60%, transparent),color-mix(in srgb, var(--charcoal) 60%, transparent)),url('{{ hero.bg_image }}');background-size:cover;background-position:center;"{% endif %}>
  <div class="wrap hero-fullbleed-inner reveal">
    <div class="eyebrow center">{{ hero.eyebrow }}</div>
    <h1>{{ hero.headline }}</h1>
    <p class="sub">{{ hero.subhead }}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="{{ hero.primary_cta.url }}">{{ hero.primary_cta.label }}</a>
      <a class="btn btn-outline-light" href="{{ hero.secondary_cta.url }}">{{ hero.secondary_cta.label }}</a>
    </div>
  </div>
</section>

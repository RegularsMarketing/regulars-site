<!DOCTYPE html>
<html lang="{{ site.business.lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% set p = site.pages[pageKey] if pageKey else null %}
<title>{{ p.seo_title if p else title }}</title>
<meta name="description" content="{{ p.seo_description if p else description }}">
<link rel="canonical" href="{{ site.business.url }}{{ page.url }}">
<meta name="robots" content="{{ 'noindex' if noindex else 'index, follow' }}">
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ site.business.name }}">
<meta property="og:title" content="{{ p.seo_title }}">
<meta property="og:description" content="{{ p.seo_description }}">
<meta property="og:url" content="{{ site.business.url }}{{ page.url }}">
<meta property="og:image" content="{{ site.business.url }}{{ site.images.hero_logo }}">
<meta name="twitter:card" content="summary_large_image">
{# Mobile browser chrome matches the page field instead of defaulting to white,
   which on a mid-tone field is a visible seam above the fold. Reuses the
   existing theme colour — no new config field. #}
<meta name="theme-color" content="{{ site.theme.colors.cream }}">
<link rel="icon" type="image/png" href="{{ site.images.logo_mark }}">
{# Webfonts load only when the config names them. An empty google_href means
   system fonts: no preconnect, no request, nothing to fall back from. #}
{% if site.theme.fonts.google_href %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="{{ site.theme.fonts.google_href }}">
<link href="{{ site.theme.fonts.google_href }}" rel="stylesheet" media="print" onload="this.media='all'">
<noscript><link href="{{ site.theme.fonts.google_href }}" rel="stylesheet"></noscript>
{% endif %}
<style>
:root{
  --cream:{{ site.theme.colors.cream }};
  --cream-2:{{ site.theme.colors.cream2 }};
  --charcoal:{{ site.theme.colors.charcoal }};
  --charcoal-2:{{ site.theme.colors.charcoal2 }};
  --orange:{{ site.theme.colors.orange }};
  --orange-dark:{{ site.theme.colors.orange_dark }};
  --line:{{ site.theme.colors.line }};
  --line-soft:{{ site.theme.colors.line_soft }};
  --font-heading:{{ site.theme.fonts.heading | safe }};
  --font-body:{{ site.theme.fonts.body | safe }};
}
</style>
<link rel="stylesheet" href="{{ assets.styles }}">
{# JSON-LD structured data. Config-driven; skipped on noindex pages, which
   have nothing to describe to a search engine. #}
{% if not noindex %}{% include "components/schema.njk" %}{% endif %}
</head>
<body>

{% include "components/nav.njk" %}

<main>
{{ content | safe }}
</main>

{% include "components/footer.njk" %}

<script defer src="{{ assets.motion }}"></script>
<script defer src="{{ assets.animations }}"></script>
<script defer src="{{ assets.site }}"></script>
{% if site.integrations and site.integrations.chat_widget and not hide_chat_widget %}{{ site.integrations.chat_widget | safe }}
{% endif %}</body>
</html>

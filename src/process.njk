---
layout: base.njk
pageKey: process
permalink: /process/
---
{% set s = site.pages.process %}
<section style="padding-top:60px;">
  <div class="wrap">
    <div class="eyebrow reveal">{{ s.eyebrow }}</div>
    <div class="section-head reveal">
      <h2>{{ s.heading }}</h2>
      <p>{{ s.subhead }}</p>
    </div>

    <div class="step-list reveal">
      {% for step in s.steps %}
      <div class="step"><div class="snum">{{ step.num }}</div><div><h3>{{ step.heading }}</h3><p>{{ step.body }}</p></div></div>
      {% endfor %}
    </div>

    <p class="reveal" style="text-align:center;font-size:14px;color:var(--charcoal-2);margin-top:8px;">{{ s.closing_note }}</p>

    <div style="text-align:center;margin-top:32px;">
      <a class="btn btn-outline" href="{{ s.cta.url }}">{{ s.cta.label }}</a>
    </div>
  </div>
</section>
